<?xml version="1.0" encoding="utf-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android"
        id="cordova-plugin-overlaydetection"
        version="1.0.0">

    <name>OverlayDetectionPlugin</name>
    <description>Detects screen overlay attacks</description>
    <license>MIT</license>

    <platform name="android">

        <config-file parent="/*" target="res/xml/config.xml">
            <feature name="OverlayDetectionPlugin">
                <param name="android-package"
                       value="com.overlay.security.OverlayDetectionPlugin"/>
            </feature>
        </config-file>

        <source-file src="src/android/OverlayDetectionPlugin.java"
                     target-dir="src/com/overlay/security"/>

    </platform>

</plugin>
